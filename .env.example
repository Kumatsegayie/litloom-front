REACT_APP_STRAPI_URL=https://api.your-domain.com
# Do not add /api or /admin at the end. Use only origin/base URL.
# Example: https://api.your-domain.com (not https://api.your-domain.com/api)
# Optional: if your backend is on same host but a custom port.
# Leave empty when you use reverse proxy on same origin.
REACT_APP_STRAPI_PORT=
